# Frontend build variables. Set these on Vercel before building.
REACT_APP_API_BASE_URL=http://localhost:5000
REACT_APP_SOCKET_URL=http://localhost:5000

# Server
MONGO_URI=your_mongodb_connection_string
JWT_SECRET=replace_with_a_long_random_secret
PORT=5000
NODE_ENV=development

# Backend CORS allowlist. For production, set this on Render to your Vercel URL.
# Use comma-separated URLs if you need preview domains or multiple clients.
CLIENT_URL=http://localhost:3000
CLIENT_URLS=http://localhost:3000

# Frontend build variables. Set these on Vercel before building.
REACT_APP_API_BASE_URL=http://localhost:5000
REACT_APP_SOCKET_URL=http://localhost:5000

# Cloudinary uploads
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Gmail API email sending
# Use OAuth credentials with the https://www.googleapis.com/auth/gmail.send scope.
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_FROM_NAME=SyncSphere
GMAIL_CLIENT_ID=your_google_oauth_client_id
GMAIL_CLIENT_SECRET=your_google_oauth_client_secret
GMAIL_REFRESH_TOKEN=your_google_oauth_refresh_token
